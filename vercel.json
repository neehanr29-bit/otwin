{
  "builds": [
    {
      "src": "api/**/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "index.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}